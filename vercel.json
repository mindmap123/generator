{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login.js"
    },
    {
      "source": "/api/auth/logout",
      "destination": "/api/auth/logout.js"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/auth/me.js"
    },
    {
      "source": "/api/import-local-data",
      "destination": "/api/import-local-data.js"
    },
    {
      "source": "/api/generate",
      "destination": "/api/generate.js"
    },
    {
      "source": "/api/reviews/last-import",
      "destination": "/api/reviews/last-import.js"
    },
    {
      "source": "/api/reviews/:id",
      "destination": "/api/reviews/[id].js"
    },
    {
      "source": "/api/reviews",
      "destination": "/api/reviews.js"
    },
    {
      "source": "/login",
      "destination": "/public/login.html"
    },
    {
      "source": "/import-data",
      "destination": "/public/import-data.html"
    },
    {
      "source": "/",
      "destination": "/public/review-generator.html"
    },
    {
      "source": "/dashboard",
      "destination": "/public/dashboard.html"
    },
    {
      "source": "/poster",
      "destination": "/public/poster.html"
    },
    {
      "source": "/admin",
      "destination": "/public/admin.html"
    },
    {
      "source": "/auth-client.js",
      "destination": "/public/auth-client.js"
    }
  ]
}
